{
  "test": "test-2-duplicates",
  "description": "Liste mit offensichtlichen Duplikaten",
  "expectedBehavior": "Mengen sollten erhöht werden: 2x Milch, 3x Käse, 2x Äpfel",
  "expectedResult": {
    "new": [
      "Brot",
      "Bananen"
    ],
    "updates": [
      {"id": "would-be-id-1", "text": "2x Milch"},
      {"id": "would-be-id-2", "text": "3x Käse"},
      {"id": "would-be-id-3", "text": "2x Äpfel"}
    ]
  },
  "expectedMessage": "2 neu, 3 zusammengeführt"
}
